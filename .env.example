# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Example: postgresql://user:password@localhost:5432/socialpulse
DATABASE_URL=

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Full public URL of the app (no trailing slash)
# Example: https://comments.tudominio.com
NEXTAUTH_URL=

# Random secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# ─── Facebook / Meta OAuth ────────────────────────────────────────────────────
# App credentials from https://developers.facebook.com
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Token used to verify Meta webhook subscriptions (you choose this value)
META_WEBHOOK_VERIFY_TOKEN=

# ─── Encryption ───────────────────────────────────────────────────────────────
# 64-character hex key used to encrypt page tokens and OpenAI keys at rest
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# ─── Public app metadata ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_APP_NAME=SocialPulse

# ─── Redis (BullMQ job queue) ─────────────────────────────────────────────────
# Example: redis://localhost:6379  |  with password: redis://:password@localhost:6379
REDIS_URL=
