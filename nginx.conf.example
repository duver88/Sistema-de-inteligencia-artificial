# nginx.conf.example
# Nginx reverse proxy configuration for SocialPulse (Next.js on port 3002).
#
# Usage:
#   1. Copy to /etc/nginx/sites-available/socialpulse
#   2. Replace every occurrence of TU_DOMINIO with your actual domain
#   3. Run: sudo certbot --nginx -d TU_DOMINIO   (to provision SSL)
#   4. sudo ln -s /etc/nginx/sites-available/socialpulse /etc/nginx/sites-enabled/
#   5. sudo nginx -t && sudo systemctl reload nginx

upstream socialpulse_app {
    server 127.0.0.1:3002;
    keepalive 64;
}

# ── HTTP → HTTPS redirect ─────────────────────────────────────────────────────
server {
    listen 80;
    listen [::]:80;
    server_name TU_DOMINIO;

    # Let's Encrypt ACME challenge
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

# ── HTTPS main server ─────────────────────────────────────────────────────────
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name TU_DOMINIO;

    # SSL — managed by Certbot (paths filled automatically after certbot run)
    ssl_certificate     /etc/letsencrypt/live/TU_DOMINIO/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/TU_DOMINIO/privkey.pem;
    include             /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam         /etc/letsencrypt/ssl-dhparams.pem;

    # ── Security headers ──────────────────────────────────────────────────────
    add_header X-Frame-Options           "SAMEORIGIN"            always;
    add_header X-Content-Type-Options    "nosniff"               always;
    add_header X-XSS-Protection          "1; mode=block"         always;
    add_header Referrer-Policy           "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy        "camera=(), microphone=(), geolocation=()" always;
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    # ── Client limits ─────────────────────────────────────────────────────────
    client_max_body_size 10M;

    # ── Proxy to Next.js ──────────────────────────────────────────────────────
    location / {
        proxy_pass         http://socialpulse_app;
        proxy_http_version 1.1;

        # WebSocket support (Next.js hot reload + app WebSockets)
        proxy_set_header   Upgrade    $http_upgrade;
        proxy_set_header   Connection "upgrade";

        # Forward real IP and host
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;

        # Timeouts
        proxy_connect_timeout 60s;
        proxy_send_timeout    60s;
        proxy_read_timeout    60s;

        # Buffer tuning for SSR responses
        proxy_buffering    on;
        proxy_buffer_size  16k;
        proxy_buffers      4 32k;
    }

    # ── Next.js static assets — cache aggressively ────────────────────────────
    location /_next/static/ {
        proxy_pass       http://socialpulse_app;
        proxy_cache_valid 200 365d;
        add_header       Cache-Control "public, max-age=31536000, immutable";
        access_log       off;
    }

    location /favicon.ico {
        proxy_pass  http://socialpulse_app;
        access_log  off;
        log_not_found off;
    }

    # ── Meta Webhook endpoint — no body size limit ────────────────────────────
    location /api/webhooks/meta {
        proxy_pass          http://socialpulse_app;
        proxy_http_version  1.1;
        proxy_set_header    Host              $host;
        proxy_set_header    X-Real-IP         $remote_addr;
        proxy_set_header    X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header    X-Forwarded-Proto $scheme;
        client_max_body_size 1M;
    }

    # ── Logging ───────────────────────────────────────────────────────────────
    access_log /var/log/nginx/socialpulse-access.log;
    error_log  /var/log/nginx/socialpulse-error.log warn;
}
