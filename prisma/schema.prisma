// Prisma schema for SocialPulse — CommentBot module
// Generator outputs to lib/generated/prisma (Prisma 7 style)

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── TENANT ───────────────────────────────────────────────────────────────
model Tenant {
  id        String   @id @default(cuid())
  name      String
  plan      Plan     @default(FREE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // OpenAI API key (AES-256-GCM encrypted, nullable)
  openaiApiKey     String?   @db.Text
  openaiKeySetAt   DateTime?

  users    User[]
  accounts SocialAccount[]
  bots     Bot[]
  comments CommentLog[]
}

enum Plan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

// ─── USER ─────────────────────────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(MEMBER)
  // Nullable so PrismaAdapter can create the user on first OAuth login
  // before the signIn callback assigns a tenant.
  tenantId String?
  tenant   Tenant?  @relation(fields: [tenantId], references: [id])

  // Facebook OAuth data
  facebookId    String?   @unique
  facebookToken String?   // Long-lived user access token (encrypted)
  tokenExpiresAt DateTime?

  // Super admin flag (for admin panel access)
  isSuperAdmin Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts Account[]
  sessions Session[]
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

// NextAuth Account (do not rename — required by NextAuth adapter)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── SOCIAL ACCOUNT ───────────────────────────────────────────────────────
// Represents a connected Facebook Page or Instagram Business Account
model SocialAccount {
  id       String   @id @default(cuid())
  tenantId String
  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  platform Platform
  pageId   String // Facebook Page ID or Instagram Account ID
  pageName String
  pageToken String @db.Text // Page access token (encrypted with AES-256-GCM)
  pictureUrl    String?
  isActive      Boolean  @default(true)
  connectedAt   DateTime @default(now())
  tokenExpiresAt DateTime?

  // For Instagram: link to its parent Facebook Page
  linkedFacebookPageId String?
  linkedPage           SocialAccount?  @relation("LinkedAccounts", fields: [linkedFacebookPageId], references: [id])
  igAccounts           SocialAccount[] @relation("LinkedAccounts")

  bots               Bot[]
  webhookSubscribed  Boolean   @default(false)
  lastPolledAt       DateTime? // Updated after each successful polling cycle

  @@unique([platform, pageId])
}

enum Platform {
  FACEBOOK
  INSTAGRAM
}

// ─── BOT ──────────────────────────────────────────────────────────────────
// One bot per Social Account. Contains all configuration.
model Bot {
  id        String        @id @default(cuid())
  tenantId  String
  tenant    Tenant        @relation(fields: [tenantId], references: [id])
  accountId String
  account   SocialAccount @relation(fields: [accountId], references: [id])
  name      String // e.g. "Bot Instagram UrbaMares"

  // Master switch
  isActive Boolean @default(false)

  // Feature toggles
  autoReply      Boolean @default(true)
  deleteNegative Boolean @default(true) // Delete offensive/negative comments
  hideSpam       Boolean @default(true) // Hide spam comments
  aiEnabled      Boolean @default(true) // Use AI for classification + reply

  // AI configuration
  aiModel      String @default("claude-sonnet-4-20250514")
  replyMaxChars Int    @default(250)
  replyTone    String @default("friendly") // friendly | formal | casual
  language     String @default("es")

  // Custom instructions for the AI (freeform text)
  systemInstructions String? @db.Text

  // Keyword rules (stored as JSON arrays)
  deleteKeywords Json @default("[]") // string[] of regex patterns to auto-delete
  spamKeywords   Json @default("[]") // string[] of regex patterns to auto-hide

  // AI-powered moderation instructions (natural language, complements keyword rules)
  deleteInstructions String? @db.Text // Natural-language instructions for when to DELETE
  spamInstructions   String? @db.Text // Natural-language instructions for when to HIDE

  // Projects (for multi-project pages like UrbaMares)
  projects Project[]

  // Knowledge base entries
  knowledgeEntries KnowledgeEntry[]

  comments CommentLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── PROJECT ──────────────────────────────────────────────────────────────
// For pages that sell multiple products/projects. The bot detects which
// project a post belongs to and uses the correct knowledge base.
model Project {
  id    String @id @default(cuid())
  botId String
  bot   Bot    @relation(fields: [botId], references: [id])
  name  String // e.g. "Diamante Campestre"

  detectionKeywords Json    @default("[]") // string[] of keywords to detect this project from post caption
  isDefault         Boolean @default(false) // Used when no project is detected

  knowledgeEntries KnowledgeEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── KNOWLEDGE ENTRY ──────────────────────────────────────────────────────
// Individual Q&A or fact entry in the bot's knowledge base.
// Can be associated with a specific Project or with the Bot globally.
model KnowledgeEntry {
  id        String   @id @default(cuid())
  botId     String
  bot       Bot      @relation(fields: [botId], references: [id])
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])
  key       String // e.g. "Precio", "Area", "Ubicacion", "WhatsApp"
  value     String   @db.Text
  category  String? // e.g. "pricing", "location", "contact", "features"
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── COMMENT LOG ──────────────────────────────────────────────────────────
// Full audit trail of every comment processed by the system.
model CommentLog {
  id       String   @id @default(cuid())
  tenantId String
  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  botId    String
  bot      Bot      @relation(fields: [botId], references: [id])
  platform Platform

  commentId  String // Meta comment ID
  postId     String // Meta post/media ID
  authorName String
  authorId   String

  originalText String        @db.Text
  action       CommentAction

  aiReply   String? @db.Text
  aiReplyId String? // ID of the reply comment created on Meta

  projectDetected String? // Which project was detected for this comment
  deletedAt       DateTime?
  repliedAt       DateTime?
  processingMs    Int? // How long the pipeline took in milliseconds
  errorMessage    String?

  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([botId, createdAt])
  @@index([platform, commentId])
}

enum CommentAction {
  REPLIED // AI generated and posted a reply
  DELETED // Comment was deleted (offensive/negative)
  HIDDEN // Comment was hidden (spam)
  IGNORED // Comment was processed but no action taken
  MANUAL_REPLY // User manually replied through the dashboard
  MANUAL_DELETE // User manually deleted through the dashboard
  ERROR // Processing failed
}
